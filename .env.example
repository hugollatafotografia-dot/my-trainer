# Required
OPENAI_API_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional if your chatbot in OpenAI is configured as an assistant for Responses API.
OPENAI_CHATBOT_ASSISTANT_ID=
OPENAI_RESPONSES_ASSISTANT_ID=
OPENAI_ASSISTANT_ID=
OPENAI_CHATBOT_ID=

# Optional fallback model when assistant id is not set.
OPENAI_CHATBOT_MODEL=gpt-4.1-mini

# Optional
OPENAI_CHATBOT_TIMEOUT_MS=20000
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Optional contact form delivery (email)
CONTACT_FORM_TO=
CONTACT_FORM_FROM=
RESEND_API_KEY=